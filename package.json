{
  "name": "deepcuts",
  "version": "0.1.0",
  "private": true,
  "description": "Listening documentaries about music — narration alternating with real Spotify tracks.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
