    "test:watch": "vitest",
    "probe-spotify": "tsx scripts/probe-spotify.ts",
    "publish-episode": "tsx scripts/publish-episode.ts",
    "publish-all-ready": "tsx scripts/publish-all-ready.ts",
    "purge-jsdelivr": "tsx scripts/purge-jsdelivr.ts",
    "lint": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/google-vertex": "^5.0.1",
    "@ai-sdk/openai": "^4.0.0",
    "@fontsource/inter": "^5.0.18",
    "ai": "^7.0.2",
    "google-auth-library": "^10.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.14.0",
